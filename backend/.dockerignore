# Virtual envs / build artifacts (rebuilt inside the image by `uv sync`)
.venv/
venv/
*.egg-info/

# Python caches
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Local OWL store / runtime data (provided by a volume at runtime)
data/

# Local model weights (air-gap delivery via artifact repo, mounted at runtime
# to /app/models — never baked into the image; would add multiple GB).
models/

# VCS / tooling
.git/
.gitignore
Dockerfile
.dockerignore
