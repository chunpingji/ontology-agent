# ============================================================
# Sample Drug Product Individual (for risk assessment demo)
# ============================================================

slpra-drug:DrugX a slpra-drug:ClinicalTrialDrug, slpra-drug:CytotoxicDrug ;
    slpra-drug:dosageForm "powder" ;
    slpra-drug:routeOfAdministration "intravenous" ;
    slpra-drug:isCytotoxic true ;
    slpra-drug:isHighlyActive true ;
    slpra-drug:hasActiveIngredient slpra-drug:API_CompoundX .

slpra-drug:API_CompoundX a slpra-drug:CytotoxicAPI ;
    slpra-drug:pde_mg_per_day "0.002"^^xsd:decimal ;
    slpra-drug:oel_ug_per_m3 "0.5"^^xsd:decimal ;
    slpra-drug:hasOEBClassification [ a slpra-drug:OEB5 ] ;
    slpra-drug:hasToxicityProfile [
        a slpra-drug:GenotoxicityProfile ;
        slpra-drug:ld50_mg_per_kg "15.0"^^xsd:decimal
    ] ;
    slpra-drug:hasInactivationDisposition [ a slpra-drug:ChemicalInactivatable ] ;
    slpra-drug:hasSolubilityCharacteristic [ a slpra-drug:WaterSolubility ] .

# ============================================================
# Sample Risk Assessment Scenario
# ============================================================

# Scenario: DrugX (cytotoxic, OEB5) on shared centrifuge CT64201
slpra-risk:Assessment_DrugX_CT64201 a slpra-risk:RiskAssessmentProcess ;
    slpra-risk:assessesProduct slpra-drug:DrugX ;
    slpra-risk:assessesEquipment slpra-equip:CT64201 ;
    slpra-risk:involvesScenario [ a slpra-risk:CytotoxicSharedLineScenario ] ;
    slpra-risk:involvesScenario [ a slpra-risk:ClinicalWithCommercialScenario ] .

# Contamination event: residue pathway for DrugX on CT64201
slpra-contam:CE_DrugX_CT64201_Residue a slpra-contam:ResidueContamination ;
    slpra-contam:hasContaminationSource slpra-drug:DrugX ;
    slpra-contam:mediatedByEquipment slpra-equip:CT64201 ;
    slpra-contam:hasContaminationSeverity slpra-risk:HighRisk .

# Compatibility assessment
slpra-risk:Compat_DrugX_CT64201 a slpra-risk:CompatibilityAssessment ;
    slpra-risk:assessesEquipmentFor slpra-equip:CT64201 ;
    slpra-risk:assessesProductFor slpra-drug:DrugX ;
    slpra-risk:compatibilityResult "conditional" ;
    slpra-risk:compatibilityCondition "Requires validated chemical inactivation and enhanced cleaning validation. OEB5 classification recommends dedicated equipment."@en .
