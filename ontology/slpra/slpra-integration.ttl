@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix obo:   <http://purl.obolibrary.org/obo/> .
@prefix slpra-integ: <https://ontology.pharma-gmp.cn/slpra/integration/> .
@prefix slpra-drug:  <https://ontology.pharma-gmp.cn/slpra/drug/> .
@prefix slpra-equip: <https://ontology.pharma-gmp.cn/slpra/equipment/> .
@prefix slpra-contam:<https://ontology.pharma-gmp.cn/slpra/contamination/> .
@prefix slpra-risk:  <https://ontology.pharma-gmp.cn/slpra/risk/> .
@prefix slpra-clean: <https://ontology.pharma-gmp.cn/slpra/cleaning/> .
@prefix slpra-facil: <https://ontology.pharma-gmp.cn/slpra/facility/> .
@prefix dron:  <http://purl.obolibrary.org/obo/DRON_> .
@prefix chebi: <http://purl.obolibrary.org/obo/CHEBI_> .
@prefix chmo:  <http://purl.obolibrary.org/obo/CHMO_> .
@prefix obi:   <http://purl.obolibrary.org/obo/OBI_> .
@prefix envo:  <http://purl.obolibrary.org/obo/ENVO_> .
@prefix ncit:  <http://purl.obolibrary.org/obo/NCIT_> .
@prefix isa88: <https://w3id.org/2021/2/7/2/isa88/> .
@prefix idmp-mprd: <https://spec.pistoiaalliance.org/idmp/ontology/ISO/ISO11615-MedicinalProducts/> .
@prefix idmp-sub:  <https://spec.pistoiaalliance.org/idmp/ontology/ISO/ISO11238-Substances/> .
@prefix idmp-phdf: <https://spec.pistoiaalliance.org/idmp/ontology/ISO/ISO11239-PharmaceuticalDoseForms/> .
@prefix atc:   <https://atcddd.fhi.no/atc_ddd_index/?code=> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

<https://ontology.pharma-gmp.cn/slpra/integration/>
    a owl:Ontology ;
    owl:versionIRI <https://ontology.pharma-gmp.cn/slpra/integration/0.1.0> ;
    rdfs:label "SLPRA Integration Module"@en ;
    rdfs:label "SLPRA 集成桥接模块"@zh ;
    rdfs:comment "Integration module that bridges all 6 SLPRA domain modules and maps to external ontologies (BFO, DrOn, ChEBI, ISA-88, IDMP-O, CHMO, OBI, ENVO, NCIT)."@en ;
    owl:imports <https://ontology.pharma-gmp.cn/slpra/drug/> ;
    owl:imports <https://ontology.pharma-gmp.cn/slpra/equipment/> ;
    owl:imports <https://ontology.pharma-gmp.cn/slpra/contamination/> ;
    owl:imports <https://ontology.pharma-gmp.cn/slpra/risk/> ;
    owl:imports <https://ontology.pharma-gmp.cn/slpra/cleaning/> ;
    owl:imports <https://ontology.pharma-gmp.cn/slpra/facility/> .

# ============================================================
# External Ontology Alignment — DrOn
# ============================================================
# 注：DrugProduct 是受管主语，rdfs:subClassOf 会被 surgical_merge 剥离，故改用 skos
# 映射（非受管谓词，可保留往返）。ClinicalDrugRole 用 owl:equivalentClass —— 它不在
# MANAGED_PREDICATES 中、可安全存活，故保持不变。

# DrugProduct ⟷ DrOn drug product（近似匹配）
slpra-drug:DrugProduct skos:closeMatch dron:00000005 .

# ClinicalDrugRole ⟷ DrOn clinical drug role（owl:equivalentClass 非受管谓词，保留）
slpra-drug:ClinicalDrugRole owl:equivalentClass dron:00000001 .

# ============================================================
# External Ontology Alignment — ChEBI（药品/API 的化学与药理角色对齐）
# ============================================================
# molecular entity 远宽于 API → broadMatch；其余为药理/化学角色 closeMatch。
# 所有 CHEBI IRI 已逐一核对 ebi.ac.uk/chebi。

# API ⟷ ChEBI molecular entity（外部更宽 → broadMatch）
slpra-drug:ActivePharmaceuticalIngredient skos:broadMatch chebi:23367 .

# 药理 / 化学角色对齐
slpra-drug:CytotoxicDrug       skos:closeMatch   chebi:35610 .   # antineoplastic agent
slpra-drug:CytotoxicAPI        skos:closeMatch   chebi:35610 .   # antineoplastic agent
slpra-drug:AntineoplasticDrug  skos:closeMatch   chebi:35610 .   # antineoplastic agent（新增可推断类，§8.0；✓ T021 核实）
slpra-drug:HormonalDrug        skos:closeMatch   chebi:24621 .   # hormone
slpra-drug:HormonalAPI         skos:closeMatch   chebi:24621 .   # hormone
slpra-drug:PenicillinDrug      skos:closeMatch   chebi:17334 .   # penicillin
slpra-drug:BetaLactamDrug      skos:closeMatch   chebi:27933 .   # beta-lactam antibiotic
slpra-drug:GenotoxicityProfile skos:relatedMatch chebi:25435 .   # mutagen（相关角色，非层级）

# ============================================================
# External Ontology Alignment — ATC（WHO 解剖治疗化学分类）
# ============================================================
# §8.0 可推断风险类的法规溯源层：ChEBI 化学/药理角色驱动运行期推断，ATC 治疗分类仅作
# 物化溯源（named-IRI provenance，不入 T026 alignment_verified 门禁——该门禁仅校验进入
# 推断的 ChEBI IRI）。IRI 用 WHO 协作中心 ATC/DDD 索引可解引用地址（WHOCC 2024 起迁至
# atcddd.fhi.no）。抗肿瘤/青霉素与各自 ATC 组语义近似 → closeMatch；HormonalDrug 跨
# G03(性激素)+H02(皮质激素)两组、为二者上位的策展聚合 → relatedMatch（关联、非等价）。
# ✓ 四个 ATC 码及标签均经 T021 字节级核实（2026-06-24）。

slpra-drug:AntineoplasticDrug skos:closeMatch   atc:L01 .   # ANTINEOPLASTIC AGENTS（✓ T021 核实）
slpra-drug:PenicillinDrug     skos:closeMatch   atc:J01C .  # BETA-LACTAM ANTIBACTERIALS, PENICILLINS（✓ T021 核实）
slpra-drug:HormonalDrug       skos:relatedMatch atc:G03 .   # SEX HORMONES AND MODULATORS OF THE GENITAL SYSTEM（✓ T021 核实）
slpra-drug:HormonalDrug       skos:relatedMatch atc:H02 .   # CORTICOSTEROIDS FOR SYSTEMIC USE（✓ T021 核实）

# ============================================================
# External Ontology Alignment — ISA-88 (IEC 61512-1)
# ============================================================
# 用 SKOS 映射而非 rdfs:subClassOf：设备类是工作台受管主语(managed subject)，而
# rdfs:subClassOf ∈ MANAGED_PREDICATES(ttl_merge.py)，会在外科式合并时被 DB 投影
# 剥离覆盖——外部对齐会静默丢失。skos:exactMatch/closeMatch 是非受管谓词，可逐字
# 保留并安全往返导出。外部 IRI 的离线 stub 见下方「External Term Stubs」。
# 说明：skos 映射在 SLPRA 类(owl:Class)间断言会产生 OWL punning，DL 推理机
# (HermiT/Pellet)允许此用法，不影响一致性；映射为策展级、不传播 DL 包含蕴含。

# 设备总类 ⟷ ISA-88 设备实体（精确匹配）
slpra-equip:Equipment        skos:exactMatch  isa88:EquipmentEntity .

# 生产设备及各机型 ⟷ ISA-88 Unit（近似匹配：每台主设备即一个 S88 Unit）
slpra-equip:ProcessEquipment skos:closeMatch  isa88:Unit .
slpra-equip:Reactor          skos:closeMatch  isa88:Unit .
slpra-equip:Centrifuge       skos:closeMatch  isa88:Unit .
slpra-equip:Dryer            skos:closeMatch  isa88:Unit .
slpra-equip:RotaryEvaporator skos:closeMatch  isa88:Unit .
slpra-equip:Granulator       skos:closeMatch  isa88:Unit .
slpra-equip:Mixer            skos:closeMatch  isa88:Unit .
slpra-equip:TabletPress      skos:closeMatch  isa88:Unit .
slpra-equip:CapsuleFiller    skos:closeMatch  isa88:Unit .
slpra-equip:CoatingMachine   skos:closeMatch  isa88:Unit .
slpra-equip:FillingMachine   skos:closeMatch  isa88:Unit .

# ============================================================
# External Ontology Alignment — IDMP-O (Pistoia/EDMC, ISO 11615/11238/11239)
# ============================================================
# 已重基到权威命名空间：Pistoia Alliance IDMP-O V1.4（MIT 许可），EDM Council 镜像
# 托管，FIBO/OMG-Commons 风格。三个模块命名空间逐字取自官方 QuickIDMPDev.ttl。
# ✓ 全部本地名已对源 artifact (github.com/dasawanaka/idmp · master · RDF/XML) 字节级核实。
# 受管主语的 subClassOf 仍会被 surgical_merge 剥离 → 一律用 skos/seeAlso/subPropertyOf。

# DrugProduct ⟷ IDMP 医药产品（近似匹配；✓ MedicinalProduct 已核实，源标签 "medicinal product"）
slpra-drug:DrugProduct skos:closeMatch idmp-mprd:MedicinalProduct .

# 商业化药品 ⟷ IDMP 已上市医药产品（✓ AuthorizedMedicinalProduct 已核实）
slpra-drug:CommercialDrug skos:closeMatch idmp-mprd:AuthorizedMedicinalProduct .

# 临床试验用药 ⟷ IDMP 研究用医药产品（✓ InvestigationalMedicinalProduct 已核实，源标签 "investigational medicinal product"）
slpra-drug:ClinicalTrialDrug skos:closeMatch idmp-mprd:InvestigationalMedicinalProduct .

# API ⟷ IDMP 化学物质（外部更宽 → broadMatch；✓ ChemicalSubstance 已核实）
slpra-drug:ActivePharmaceuticalIngredient skos:broadMatch idmp-sub:ChemicalSubstance .

# 辅料 ⟷ IDMP 非活性成分（✓ InactiveIngredient 已核实，较占位 Ingredient 更精确）
slpra-drug:Excipient skos:closeMatch idmp-sub:InactiveIngredient .

# 数据属性 ⟷ IDMP ISO 11239 模块（seeAlso：经核实 ISO11239 全量 artifact 无 PharmaceuticalDoseForm /
# RouteOfAdministration 裸类——剂型/给药途径在 IDMP-O 为受控词表 + ISO11615 给药对象属性建模；
# 故指向已核实的模块本体 IRI 而非杜撰的类。SLPRA 用字面值，IDMP 用受控对象，本即弱关联）
slpra-drug:dosageForm            rdfs:seeAlso idmp-phdf: .
slpra-drug:routeOfAdministration rdfs:seeAlso idmp-phdf: .

# IDMP ingredient relation alignment（✓ idmp-sub:hasIngredient 已核实；subPropertyOf 非受管谓词，保留）
slpra-drug:hasActiveIngredient rdfs:subPropertyOf idmp-sub:hasIngredient .

# ============================================================
# External Ontology Alignment — Cleaning Module（CHMO / OBI，OBO Foundry）
# ============================================================
# 分析方法对到 CHMO(化学方法本体)、取样/测定对到 OBI(生物医学研究本体)。均为 OBO
# Foundry、PURL 可解引用；IRI 已逐一经 EBI OLS 核对。受管主语用 skos(非受管谓词)。
# TOC 法 / SIP 灭菌在 CHMO·OBI 暂无对应过程类（OBI 仅有 sterilization function，
# 属 BFO:function 范畴不符），故不强行对齐。

# 分析方法 ⟷ OBI assay（外部更宽：任何"检验材料以产出信息"的计划过程 → broadMatch）
slpra-clean:AnalyticalMethod skos:broadMatch obi:0000070 .

# HPLC 法 ⟷ CHMO 高效液相色谱法
slpra-clean:HPLCMethod skos:closeMatch chmo:0001009 .

# 紫外分光光度法 ⟷ CHMO 紫外-可见分光光度法
slpra-clean:UVSpectrophotometry skos:closeMatch chmo:0000292 .

# 取样过程 ⟷ OBI 标本采集过程
slpra-clean:SamplingProcess skos:closeMatch obi:0000659 .

# ============================================================
# External Ontology Alignment — Facility Module（ENVO，OBO Foundry）
# ============================================================
# 洁净区对到 ENVO(环境本体) cleanroom；ISO 14644 等级已在 facility 模块标签注明，
# 该标准无免费 RDF 词条 IRI，故不另设对齐。

# 洁净区 ⟷ ENVO 洁净室
slpra-facil:CleanArea skos:closeMatch envo:03600000 .

# ============================================================
# External Ontology Alignment — Contamination Module（NCIT，OBO 分发）
# ============================================================
# 空气传播途径对到 NCIT 空气传播；污染事件总类弱关联 NCIT"使用中污染"——CFDI 四途径
# 为本项目特有建模，NCIT 无对应总类，故仅 relatedMatch(非等价、非层级)。

# 空气传播 ⟷ NCIT 空气传播
slpra-contam:AirborneTransmission skos:closeMatch ncit:C128353 .

# 污染事件 ⟷ NCIT 使用中污染（弱关联）
slpra-contam:ContaminationEvent skos:relatedMatch ncit:C63018 .

# ============================================================
# External Term Stubs (offline MIREOT)
# ============================================================
# MIREOT 最小引用：为本模块对齐引用的外部术语提供本地 stub（类型 / 双语标签 / 来源
# rdfs:isDefinedBy），使其在离线容器内可解析、可在编辑器显示，且不拉入外部本体的
# 全部公理。仿照 lib/bfo.ttl 离线子集做法。如需权威全量定义，用源本体覆盖本节即可。
# 这些 stub 主语均为外部 IRI（非 managed subject），surgical_merge 逐字保留。

# --- ISA-88 / IEC 61512-1（物理模型） ---
isa88:EquipmentEntity a owl:Class ;
    rdfs:label "Equipment Entity"@en ;
    rdfs:label "设备实体"@zh ;
    rdfs:isDefinedBy <https://w3id.org/2021/2/7/2/isa88/> ;
    rdfs:comment "ISA-88 physical model — generic equipment entity (offline MIREOT stub)."@en .

isa88:Unit a owl:Class ;
    rdfs:subClassOf isa88:EquipmentEntity ;
    rdfs:label "Unit"@en ;
    rdfs:label "单元"@zh ;
    rdfs:isDefinedBy <https://w3id.org/2021/2/7/2/isa88/> ;
    rdfs:comment "ISA-88 Unit — 围绕一台主处理设备(如反应器)的设备/控制模块集合 (offline MIREOT stub)."@en .

# --- ChEBI（IRI 已逐一核对 ebi.ac.uk/chebi） ---
chebi:23367 a owl:Class ;
    rdfs:label "molecular entity"@en ;
    rdfs:label "分子实体"@zh ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/chebi.owl> ;
    rdfs:comment "ChEBI molecular entity (offline MIREOT stub)."@en .

chebi:35610 a owl:Class ;
    rdfs:label "antineoplastic agent"@en ;
    rdfs:label "抗肿瘤剂"@zh ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/chebi.owl> ;
    rdfs:comment "ChEBI antineoplastic agent (offline MIREOT stub)."@en .

chebi:24621 a owl:Class ;
    rdfs:label "hormone"@en ;
    rdfs:label "激素"@zh ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/chebi.owl> ;
    rdfs:comment "ChEBI hormone (offline MIREOT stub)."@en .

chebi:17334 a owl:Class ;
    rdfs:label "penicillin"@en ;
    rdfs:label "青霉素"@zh ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/chebi.owl> ;
    rdfs:comment "ChEBI penicillin (offline MIREOT stub)."@en .

chebi:27933 a owl:Class ;
    rdfs:label "beta-lactam antibiotic"@en ;
    rdfs:label "β-内酰胺类抗生素"@zh ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/chebi.owl> ;
    rdfs:comment "ChEBI beta-lactam antibiotic (offline MIREOT stub)."@en .

chebi:25435 a owl:Class ;
    rdfs:label "mutagen"@en ;
    rdfs:label "诱变剂"@zh ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/chebi.owl> ;
    rdfs:comment "ChEBI mutagen (offline MIREOT stub)."@en .

# --- ATC（WHO 解剖治疗化学分类码；IRI/标签经 T021 字节级核实 ✓；§8.0 溯源用，非推断驱动） ---
atc:L01 a owl:Class ;
    rdfs:label "ANTINEOPLASTIC AGENTS"@en ;
    rdfs:label "抗肿瘤药"@zh ;
    rdfs:isDefinedBy <https://atcddd.fhi.no/atc_ddd_index/> ;
    rdfs:comment "WHO ATC L01 antineoplastic agents (offline MIREOT stub; ✓ T021 核实)."@en .

atc:J01C a owl:Class ;
    rdfs:label "BETA-LACTAM ANTIBACTERIALS, PENICILLINS"@en ;
    rdfs:label "β-内酰胺类抗菌药，青霉素类"@zh ;
    rdfs:isDefinedBy <https://atcddd.fhi.no/atc_ddd_index/> ;
    rdfs:comment "WHO ATC J01C beta-lactam antibacterials, penicillins (offline MIREOT stub; ✓ T021 核实)."@en .

atc:G03 a owl:Class ;
    rdfs:label "SEX HORMONES AND MODULATORS OF THE GENITAL SYSTEM"@en ;
    rdfs:label "性激素及生殖系统调节剂"@zh ;
    rdfs:isDefinedBy <https://atcddd.fhi.no/atc_ddd_index/> ;
    rdfs:comment "WHO ATC G03 sex hormones and modulators of the genital system (offline MIREOT stub; ✓ T021 核实)."@en .

atc:H02 a owl:Class ;
    rdfs:label "CORTICOSTEROIDS FOR SYSTEMIC USE"@en ;
    rdfs:label "全身用皮质激素"@zh ;
    rdfs:isDefinedBy <https://atcddd.fhi.no/atc_ddd_index/> ;
    rdfs:comment "WHO ATC H02 corticosteroids for systemic use (offline MIREOT stub; ✓ T021 核实)."@en .

# --- DrOn ---
dron:00000005 a owl:Class ;
    rdfs:label "drug product"@en ;
    rdfs:label "药品"@zh ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/dron.owl> ;
    rdfs:comment "DrOn drug product (offline MIREOT stub)."@en .

dron:00000001 a owl:Class ;
    rdfs:label "clinical drug role"@en ;
    rdfs:label "临床药物角色"@zh ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/dron.owl> ;
    rdfs:comment "DrOn clinical drug role (offline MIREOT stub)."@en .

# --- IDMP-O / Pistoia·EDMC（ISO 11615 医药产品 · 11238 物质 · 11239 剂型） ---
# 命名空间逐字取自官方 QuickIDMPDev.ttl；下列类/属性本地名均已对源 RDF/XML artifact 字节级核实(✓)。
idmp-mprd:MedicinalProduct a owl:Class ;
    rdfs:label "medicinal product"@en ;
    rdfs:label "医药产品"@zh ;
    rdfs:isDefinedBy <https://spec.pistoiaalliance.org/idmp/ontology/ISO/ISO11615-MedicinalProducts/> ;
    rdfs:comment "IDMP-O ISO 11615 medicinal product (offline MIREOT stub; ✓ 已核实，源标签 medicinal product)."@en .

idmp-mprd:AuthorizedMedicinalProduct a owl:Class ;
    rdfs:label "Authorized Medicinal Product"@en ;
    rdfs:label "已上市医药产品"@zh ;
    rdfs:isDefinedBy <https://spec.pistoiaalliance.org/idmp/ontology/ISO/ISO11615-MedicinalProducts/> ;
    rdfs:comment "IDMP-O ISO 11615 authorised medicinal product (offline MIREOT stub; ✓ 已核实)."@en .

idmp-mprd:InvestigationalMedicinalProduct a owl:Class ;
    rdfs:label "investigational medicinal product"@en ;
    rdfs:label "研究用医药产品"@zh ;
    rdfs:isDefinedBy <https://spec.pistoiaalliance.org/idmp/ontology/ISO/ISO11615-MedicinalProducts/> ;
    rdfs:comment "IDMP-O ISO 11615 investigational medicinal product (offline MIREOT stub; ✓ 已核实，源标签 investigational medicinal product)."@en .

idmp-sub:ChemicalSubstance a owl:Class ;
    rdfs:label "Chemical Substance"@en ;
    rdfs:label "化学物质"@zh ;
    rdfs:isDefinedBy <https://spec.pistoiaalliance.org/idmp/ontology/ISO/ISO11238-Substances/> ;
    rdfs:comment "IDMP-O ISO 11238 chemical substance (offline MIREOT stub; ✓ 已核实)."@en .

idmp-sub:InactiveIngredient a owl:Class ;
    rdfs:label "Inactive Ingredient"@en ;
    rdfs:label "非活性成分"@zh ;
    rdfs:isDefinedBy <https://spec.pistoiaalliance.org/idmp/ontology/ISO/ISO11238-Substances/> ;
    rdfs:comment "IDMP-O ISO 11238 inactive ingredient ≈ excipient (offline MIREOT stub; ✓ 已核实)."@en .

# ISO 11239 模块未将剂型/给药途径建为裸类（源 artifact 已核实：实为受控词表 + ISO11615 给药对象
# 属性建模）。此处仅为模块本体 stub，slpra dosageForm/routeOfAdministration 以 rdfs:seeAlso 指向它。
idmp-phdf: a owl:Ontology ;
    rdfs:label "ISO 11239 Pharmaceutical Dose Forms & Routes of Administration (IDMP-O)"@en ;
    rdfs:label "ISO 11239 药物剂型与给药途径（IDMP-O）"@zh ;
    rdfs:comment "IDMP-O ISO 11239 module — 剂型/单位/给药途径/包装的受控词表 (offline MIREOT stub; ✓ 模块 IRI 已核实)."@en .

idmp-sub:hasIngredient a owl:ObjectProperty ;
    rdfs:label "has ingredient"@en ;
    rdfs:label "含成分"@zh ;
    rdfs:isDefinedBy <https://spec.pistoiaalliance.org/idmp/ontology/ISO/ISO11238-Substances/> ;
    rdfs:comment "IDMP-O ISO 11238 ingredient relation (offline MIREOT stub; ✓ 已核实)."@en .

# --- CHMO（化学方法本体，OBO Foundry；IRI 经 EBI OLS 核对） ---
chmo:0001009 a owl:Class ;
    rdfs:label "high-performance liquid chromatography"@en ;
    rdfs:label "高效液相色谱法"@zh ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/chmo.owl> ;
    rdfs:comment "CHMO high-performance liquid chromatography (offline MIREOT stub)."@en .

chmo:0000292 a owl:Class ;
    rdfs:label "ultraviolet-visible spectrophotometry"@en ;
    rdfs:label "紫外-可见分光光度法"@zh ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/chmo.owl> ;
    rdfs:comment "CHMO ultraviolet-visible spectrophotometry (offline MIREOT stub)."@en .

# --- OBI（生物医学研究本体，OBO Foundry） ---
obi:0000070 a owl:Class ;
    rdfs:label "assay"@en ;
    rdfs:label "测定"@zh ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/obi.owl> ;
    rdfs:comment "OBI assay — 检验材料实体以产出信息的计划过程 (offline MIREOT stub)."@en .

obi:0000659 a owl:Class ;
    rdfs:label "specimen collection process"@en ;
    rdfs:label "标本采集过程"@zh ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/obi.owl> ;
    rdfs:comment "OBI specimen collection process (offline MIREOT stub)."@en .

# --- ENVO（环境本体，OBO Foundry） ---
envo:03600000 a owl:Class ;
    rdfs:label "cleanroom"@en ;
    rdfs:label "洁净室"@zh ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/envo.owl> ;
    rdfs:comment "ENVO cleanroom (offline MIREOT stub)."@en .

# --- NCIT（NCI 叙词表，OBO 分发） ---
ncit:C128353 a owl:Class ;
    rdfs:label "Airborne Transmission"@en ;
    rdfs:label "空气传播"@zh ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/ncit.owl> ;
    rdfs:comment "NCIT airborne transmission (offline MIREOT stub)."@en .

ncit:C63018 a owl:Class ;
    rdfs:label "Contamination during Use"@en ;
    rdfs:label "使用中污染"@zh ;
    rdfs:isDefinedBy <http://purl.obolibrary.org/obo/ncit.owl> ;
    rdfs:comment "NCIT contamination during use (offline MIREOT stub)."@en .

# ============================================================
# Cross-Module Bridging Properties
# ============================================================

# Equipment → Cleaning Process
slpra-equip:cleanedBy a owl:ObjectProperty ;
    rdfs:domain slpra-equip:Equipment ;
    rdfs:range slpra-clean:CleaningProcess ;
    rdfs:label "cleaned by"@en ;
    rdfs:label "清洁方式"@zh .

# Facility → Equipment containment
slpra-facil:containsEquipment rdfs:range slpra-equip:Equipment .

# Risk Assessment → Contamination Event
slpra-risk:identifiesHazard rdfs:range slpra-contam:ContaminationEvent .

# Contamination → Risk Level
slpra-contam:hasContaminationSeverity rdfs:range slpra-risk:RiskLevel .

# ============================================================
# Cross-Module Bridging Axioms
# ============================================================

# Equipment in clean area → located in a CleanArea production room
# (linking M2 equipment to M6 facility classification)
[] a owl:Restriction ;
    owl:onProperty slpra-equip:locatedIn ;
    owl:someValuesFrom [
        a owl:Class ;
        rdfs:subClassOf slpra-facil:ProductionRoom ;
        rdfs:subClassOf [
            a owl:Restriction ;
            owl:onProperty slpra-facil:belongsToArea ;
            owl:someValuesFrom slpra-facil:CleanArea
        ]
    ] .
